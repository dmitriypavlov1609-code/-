# Fleet AI Telegram Bot - Environment Variables

# ============================================================================
# Required: Telegram
# ============================================================================
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ============================================================================
# Required: LLM API (CometAPI or OpenAI)
# ============================================================================
# Option 1: CometAPI
COMETAPI_API_KEY=your_cometapi_key
COMETAPI_BASE_URL=https://api.cometapi.com/v1/chat/completions

# Option 2: OpenAI
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_MODEL=gpt-5

# ============================================================================
# Database: SQLite (default) or PostgreSQL
# ============================================================================
# SQLite (default - works out of the box)
BOT_DB_PATH=bot_data.sqlite3

# PostgreSQL (Supabase)
# Uncomment to enable PostgreSQL
# USE_POSTGRES=true
# POSTGRES_URL=postgresql://postgres:your_password@db.your-project.supabase.co:5432/postgres

# ============================================================================
# Admin IDs (comma-separated Telegram user IDs)
# ============================================================================
ADMIN_IDS=123456789,987654321

# ============================================================================
# RAG & Embeddings (Optional - requires PostgreSQL + OpenAI API)
# ============================================================================
# Enable RAG features
# RAG_ENABLED=false

# OpenAI embeddings
# OPENAI_API_KEY=sk-your-openai-key
# EMBEDDING_MODEL=text-embedding-3-small

# RAG configuration
# RAG_TOP_K=5
# RAG_CHUNK_SIZE=512
# RAG_CHUNK_OVERLAP=50
